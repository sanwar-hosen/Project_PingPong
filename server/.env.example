# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────

# For LOCAL development (using docker-compose.yml at the monorepo root):
DATABASE_URL="postgresql://pingpong:pingpong@localhost:5432/pingpong"

# For PRODUCTION on Railway:
# Railway auto-populates DATABASE_URL from the Postgres plugin — no manual entry needed.
# But you can override it here if connecting to an external DB.

# ──────────────────────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────────────────────

PORT=3000

# The public-facing base URL of this server (no trailing slash).
# LOCAL:      http://localhost:3000
# PRODUCTION: https://your-app-name.up.railway.app
BASE_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────────
# DASHBOARD SECURITY
# ──────────────────────────────────────────────────────────────────────────────

# A long random string that protects the /dashboard route.
# Generate one at: https://randomkeygen.com (use a 256-bit key or longer)
# Access the dashboard at: https://your-app.up.railway.app/dashboard?key=YOUR_SECRET
DASHBOARD_SECRET="replace-me-with-a-long-random-secret"

# ──────────────────────────────────────────────────────────────────────────────
# NODE ENVIRONMENT
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV="development"
