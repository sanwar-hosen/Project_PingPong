<%- include('partials/header', { title: 'PingPong — ' + (email.subject || 'Email Detail') }) %>

<main class="container">
  <!-- ── Back Link ────────────────────────────────────────────────────── -->
  <div class="page-header">
    <a href="/dashboard?key=<%= dashboardKey %>" class="back-link" id="back-to-list">← Back to all emails</a>
  </div>

  <!-- ── Email Info Card ──────────────────────────────────────────────── -->
  <section class="detail-hero" id="email-info-card">
    <div class="detail-hero-left">
      <h1 class="detail-subject" id="detail-subject">
        <%= email.subject || '(No subject)' %>
      </h1>
      <div class="detail-meta">
        <div class="detail-meta-item">
          <span class="detail-meta-label">To</span>
          <span class="detail-meta-value" id="detail-recipient"><%= email.recipient || '(Unknown)' %></span>
        </div>
        <div class="detail-meta-item">
          <span class="detail-meta-label">Sent</span>
          <span class="detail-meta-value" id="detail-sent-at">
            <%= new Date(email.sentAt).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %>
            at
            <%= new Date(email.sentAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
          </span>
        </div>
        <div class="detail-meta-item">
          <span class="detail-meta-label">Tracking ID</span>
          <span class="detail-meta-value detail-tracking-id" id="detail-tracking-id"><%= email.id %></span>
        </div>
      </div>
    </div>
    <div class="detail-hero-right">
      <div class="detail-open-count-display" id="detail-open-count">
        <span class="detail-open-number"><%= opensSummary.confirmed %></span>
        <span class="detail-open-label"><%= opensSummary.confirmed === 1 ? 'Confirmed Open' : 'Confirmed Opens' %></span>
      </div>
      <% if (opensSummary.filtered > 0 || opensSummary.medium > 0 || opensSummary.low > 0) { %>
      <div class="detail-confidence-breakdown" id="detail-confidence-breakdown">
        <% if (opensSummary.high > 0) { %>
          <span class="conf-chip conf-high" title="High confidence: desktop client, deliberate open">✅ <%= opensSummary.high %> High</span>
        <% } %>
        <% if (opensSummary.medium > 0) { %>
          <span class="conf-chip conf-medium" title="Medium confidence: mobile app, may be notification/sync prefetch">⚠️ <%= opensSummary.medium %> Medium</span>
        <% } %>
        <% if (opensSummary.low > 0) { %>
          <span class="conf-chip conf-low" title="Low confidence: unrecognised client or ambiguous signal">❓ <%= opensSummary.low %> Low</span>
        <% } %>
        <% if (opensSummary.filtered > 0) { %>
          <span class="conf-chip conf-filtered" title="Bot / proxy hits — definitively non-human, excluded from counts">🤖 <%= opensSummary.filtered %> Filtered</span>
        <% } %>
      </div>
      <% } %>
    </div>
  </section>

  <% if (opens.length === 0) { %>
    <!-- ── No Opens Yet ─────────────────────────────────────────────── -->
    <section class="detail-empty" id="detail-empty-state">
      <div class="detail-empty-icon">👀</div>
      <h2>No opens recorded yet</h2>
      <p>When the recipient opens this email and loads images, open events will appear here with timestamp, location, and device info.</p>
      <div class="detail-caveat">
        <strong>Note:</strong> Some email clients block remote images by default, which prevents open tracking until the recipient clicks "Show images."
      </div>
    </section>
  <% } else { %>

    <!-- ── Opens Over Time (Mini Bar Chart) ──────────────────────────── -->
    <% if (timelineData.length > 0) { %>
      <section class="detail-section" id="opens-timeline-section">
        <h2 class="detail-section-title">📊 Opens Over Time</h2>
        <div class="timeline-chart" id="opens-timeline-chart">
          <div class="timeline-bars">
            <% timelineData.forEach(function(day) { %>
              <div class="timeline-bar-group">
                <div class="timeline-bar-value"><%= day.count %></div>
                <div class="timeline-bar" style="height: <%= maxDayCount > 0 ? Math.max((day.count / maxDayCount) * 100, 8) : 8 %>%;" title="<%= day.date %>: <%= day.count %> open<%= day.count !== 1 ? 's' : '' %>"></div>
                <div class="timeline-bar-label">
                  <%= new Date(day.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </section>
    <% } %>

    <!-- ── Open Events Table ────────────────────────────────────────── -->
    <section class="detail-section" id="open-events-section">
      <h2 class="detail-section-title">📋 Open Event History</h2>
      <p class="detail-section-subtitle">
        Every time the tracking pixel was loaded, sorted oldest to newest.
      </p>

      <div class="table-wrapper">
        <table class="email-table detail-table" id="open-events-table">
          <thead>
            <tr>
              <th class="text-center">#</th>
              <th>Opened At</th>
              <th>Location</th>
              <th>Device / Client</th>
              <th class="text-center">Confidence</th>
              <th class="col-ip">IP Address</th>
            </tr>
          </thead>
          <tbody>
            <% opens.forEach(function(open) { %>
              <% if (open.isFiltered) { %>
              <!-- Filtered (bot/proxy) row — shown muted at the bottom, not counted -->
              <tr class="open-event-row open-event-filtered" id="open-event-<%= open.id %>" title="Filtered: this hit was identified as a bot, proxy, or scanner and is excluded from open counts">
                <td class="text-center">
                  <span class="open-number-badge open-number-filtered">🤖</span>
                </td>
                <td class="cell-opened-at">
                  <span class="opened-date" title="<%= new Date(open.openedAt).toISOString() %>">
                    <%= new Date(open.openedAt).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                  <span class="opened-time">
                    <%= new Date(open.openedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
                  </span>
                </td>
                <td class="cell-location">
                  <span class="location-unknown">N/A (proxy IP)</span>
                </td>
                <td class="cell-device">
                  <span class="device-label filtered-label" title="<%= open.userAgent %>">
                    🤖 <%= open.parsedUA.label %>
                  </span>
                </td>
                <td class="text-center">
                  <span class="conf-badge conf-badge-filtered">Filtered</span>
                </td>
                <td class="cell-ip col-ip">
                  <code class="ip-address"><%= open.ipAddress %></code>
                </td>
              </tr>
              <% } else { %>
              <tr class="open-event-row" id="open-event-<%= open.id %>">
                <td class="text-center">
                  <span class="open-number-badge"><%= open.openNumber %></span>
                </td>
                <td class="cell-opened-at">
                  <span class="opened-date" title="<%= new Date(open.openedAt).toISOString() %>">
                    <%= new Date(open.openedAt).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                  <span class="opened-time">
                    <%= new Date(open.openedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
                  </span>
                </td>
                <td class="cell-location">
                  <% if (open.approxLocation) { %>
                    <span class="location-text" title="<%= open.approxLocation %>">
                      📍 <%= open.approxLocation %>
                    </span>
                  <% } else { %>
                    <span class="location-unknown">Unknown</span>
                  <% } %>
                </td>
                <td class="cell-device">
                  <span class="device-label" title="<%= open.userAgent %>">
                    <% if (open.parsedUA.device === 'iPhone' || open.parsedUA.device === 'iPad') { %>📱
                    <% } else if (open.parsedUA.device === 'Android') { %>📱
                    <% } else if (open.parsedUA.device === 'macOS') { %>💻
                    <% } else if (open.parsedUA.device === 'Windows') { %>🖥️
                    <% } else if (open.parsedUA.device === 'Linux') { %>🐧
                    <% } else { %>🌐
                    <% } %>
                    <%= open.parsedUA.label %>
                  </span>
                </td>
                <td class="text-center">
                  <% if (open.confidence === 'HIGH') { %>
                    <span class="conf-badge conf-badge-high" title="High confidence: desktop client, deliberate open">✅ High</span>
                  <% } else if (open.confidence === 'MEDIUM') { %>
                    <span class="conf-badge conf-badge-medium" title="Medium confidence: mobile app — may be notification or background sync">⚠️ Medium</span>
                  <% } else { %>
                    <span class="conf-badge conf-badge-low" title="Low confidence: unrecognised client or ambiguous signal">❓ Low</span>
                  <% } %>
                </td>
                <td class="cell-ip col-ip">
                  <code class="ip-address"><%= open.ipAddress %></code>
                </td>
              </tr>
              <% } %>
            <% }); %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- ── Caveats Notice ───────────────────────────────────────────── -->
    <section class="detail-caveats" id="detail-caveats">
      <h3>⚠️ Tracking Accuracy &amp; Confidence Guide</h3>
      <ul>
        <li><strong>✅ High Confidence:</strong> Desktop email clients (Outlook, Thunderbird, Apple Mail on Mac) and desktop webmail (Chrome, Firefox) — these only load images when a human actively opens the message.</li>
        <li><strong>⚠️ Medium Confidence:</strong> Mobile email apps (Gmail app, Apple Mail on iPhone/iPad, Outlook mobile) — the OS or app may prefetch email content when a notification arrives, before the user actually reads it. The open may be genuine or may be a background prefetch.</li>
        <li><strong>❓ Low Confidence:</strong> Unrecognised or ambiguous User-Agent — treat these with scepticism.</li>
        <li><strong>🤖 Filtered (excluded):</strong> Definitively non-human hits — Google Image Proxy, Apple Privacy Relay, Yahoo Mail Proxy, corporate email security scanners (Barracuda, Proofpoint, Mimecast, etc.), and automated HTTP clients. These are recorded for audit purposes but never counted as opens.</li>
        <li><strong>Gmail-to-Gmail:</strong> Confirmed opens from Gmail users will show Google's proxy server location (e.g. Mountain View, CA) instead of the recipient's real location. This is unavoidable with pixel tracking.</li>
        <li><strong>Image blocking:</strong> Some clients block remote images by default — the email may have been read without triggering any tracked open.</li>
      </ul>
    </section>
  <% } %>
</main>

<script>
  (function() {
    const emailId = '<%= email.id %>';
    const dashboardKey = '<%= dashboardKey %>';
    const pollInterval = 5000; // 5 seconds
    
    async function updateDetail() {
      try {
        const response = await fetch(`/dashboard/email/${emailId}?format=json&key=${dashboardKey}`);
        if (!response.ok) {
          console.error('[Detail Live] Failed to fetch updates, status:', response.status);
          return;
        }
        
        const data = await response.json();
        const opens = data.opens || [];
        const summary = data.opensSummary || { confirmed: 0, high: 0, medium: 0, low: 0, filtered: 0 };
        
        // 1. If currently in empty state and we have open events, reload to show chart & tables
        const emptyState = document.getElementById('detail-empty-state');
        if (emptyState && opens.length > 0) {
          location.reload();
          return;
        }
        
        if (opens.length === 0) return;
        
        // 2. Check if confirmed opens count has increased
        const tbody = document.querySelector('#open-events-table tbody');
        if (!tbody) return;
        
        const currentConfirmedCount = tbody.querySelectorAll('.open-event-row:not(.open-event-filtered)').length;
        const confirmedOpens = opens.filter(o => !o.isFiltered);
        if (confirmedOpens.length > currentConfirmedCount) {
          // Update large open count counter (confirmed only)
          const numDisplay = document.querySelector('.detail-open-number');
          const labelDisplay = document.querySelector('.detail-open-label');
          if (numDisplay) numDisplay.textContent = summary.confirmed;
          if (labelDisplay) labelDisplay.textContent = summary.confirmed === 1 ? 'Confirmed Open' : 'Confirmed Opens';
          
          // Pulse the open counter badge
          const displayGroup = document.querySelector('.detail-open-count-display');
          if (displayGroup) {
            displayGroup.classList.add('badge-pulse');
            setTimeout(() => {
              displayGroup.classList.remove('badge-pulse');
            }, 2000);
          }
          
          // Update timeline chart
          if (data.timelineData) {
            renderTimelineChart(data.timelineData, data.maxDayCount);
          }
          
          // Append new rows
          for (let i = currentConfirmedCount; i < confirmedOpens.length; i++) {
            const open = confirmedOpens[i];
            const tr = document.createElement('tr');
            tr.className = 'open-event-row row-highlight';
            tr.id = `open-event-${open.id}`;
            
            const openedAtDate = new Date(open.openedAt);
            const dateStr = openedAtDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
            const timeStr = openedAtDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            
            let locationHtml = '<span class="location-unknown">Unknown</span>';
            if (open.approxLocation) {
              locationHtml = `<span class="location-text" title="${escapeHtml(open.approxLocation)}">📍 ${escapeHtml(open.approxLocation)}</span>`;
            }
            
            const device = open.parsedUA.device;
            let icon = '🌐';
            if (device === 'iPhone' || device === 'iPad' || device === 'Android') {
              icon = '📱';
            } else if (device === 'macOS') {
              icon = '💻';
            } else if (device === 'Windows') {
              icon = '🖥️';
            } else if (device === 'Linux') {
              icon = '🐧';
            }
            
            let confBadge = '';
            if (open.confidence === 'HIGH') {
              confBadge = '<span class="conf-badge conf-badge-high" title="High confidence: desktop client, deliberate open">✅ High</span>';
            } else if (open.confidence === 'MEDIUM') {
              confBadge = '<span class="conf-badge conf-badge-medium" title="Medium confidence: mobile app — may be notification or background sync">⚠️ Medium</span>';
            } else {
              confBadge = '<span class="conf-badge conf-badge-low" title="Low confidence: unrecognised client or ambiguous signal">❓ Low</span>';
            }
            
            tr.innerHTML = `
              <td class="text-center">
                <span class="open-number-badge">${open.openNumber}</span>
              </td>
              <td class="cell-opened-at">
                <span class="opened-date" title="${openedAtDate.toISOString()}">${dateStr}</span>
                <span class="opened-time">${timeStr}</span>
              </td>
              <td class="cell-location">
                ${locationHtml}
              </td>
              <td class="cell-device">
                <span class="device-label" title="${escapeHtml(open.userAgent)}">
                  ${icon} ${escapeHtml(open.parsedUA.label)}
                </span>
              </td>
              <td class="text-center">
                ${confBadge}
              </td>
              <td class="cell-ip col-ip">
                <code class="ip-address">${escapeHtml(open.ipAddress)}</code>
              </td>
            `;
            
            tbody.appendChild(tr);
            
            // Remove highlight class after animation finishes
            setTimeout(() => {
              tr.classList.remove('row-highlight');
            }, 2000);
          }
        }
      } catch (err) {
        console.error('[Detail Live] Error polling data:', err);
      }
    }
    
    function renderTimelineChart(timelineData, maxDayCount) {
      const container = document.querySelector('.timeline-bars');
      if (!container) return;
      
      let html = '';
      timelineData.forEach(day => {
        const pct = maxDayCount > 0 ? Math.max((day.count / maxDayCount) * 100, 8) : 8;
        const dateObj = new Date(day.date + 'T00:00:00');
        const dateLabel = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const sText = day.count !== 1 ? 'opens' : 'open';
        
        html += `
          <div class="timeline-bar-group">
            <div class="timeline-bar-value">${day.count}</div>
            <div class="timeline-bar" style="height: ${pct}%;" title="${day.date}: ${day.count} ${sText}"></div>
            <div class="timeline-bar-label">${dateLabel}</div>
          </div>
        `;
      });
      container.innerHTML = html;
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }
    
    // Start polling on page load
    setInterval(updateDetail, pollInterval);
  })();
</script>

<%- include('partials/footer') %>
