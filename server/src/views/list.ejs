<%- include('partials/header', { title: 'PingPong — Tracked Emails' }) %>

<main class="container">
  <div class="page-header">
    <h1>📬 Tracked Emails</h1>
    <p class="subtitle">All outgoing tracked emails and their open counts</p>
  </div>

  <% if (!emails || emails.length === 0) { %>
    <!-- ── Empty State ──────────────────────────────────────────────────── -->
    <div class="empty-state">
      <div class="empty-state-icon">📭</div>
      <h2>No tracked emails yet</h2>
      <p>
        Once you send an email with the PingPong Chrome extension installed,
        it will appear here with live open tracking.
      </p>
      <div class="empty-state-steps">
        <div class="step">
          <span class="step-number">1</span>
          <span>Install the PingPong extension</span>
        </div>
        <div class="step">
          <span class="step-number">2</span>
          <span>Compose &amp; send an email in Gmail</span>
        </div>
        <div class="step">
          <span class="step-number">3</span>
          <span>Come back here to see opens</span>
        </div>
      </div>
    </div>
  <% } else { %>
    <!-- ── Stats Bar ────────────────────────────────────────────────────── -->
    <div class="stats-bar">
      <div class="stat-card">
        <span class="stat-value"><%= emails.length %></span>
        <span class="stat-label">Total Emails</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= emails.reduce((sum, e) => sum + e.opensSummary.confirmed, 0) %></span>
        <span class="stat-label">Confirmed Opens</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= emails.filter(e => e.opensSummary.confirmed > 0).length %></span>
        <span class="stat-label">Emails Opened</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= emails.reduce((sum, e) => sum + e.opensSummary.filtered, 0) %></span>
        <span class="stat-label">Bot / Proxy Hits</span>
      </div>
    </div>

    <!-- ── Email Table ──────────────────────────────────────────────────── -->
    <div class="table-wrapper">
      <table class="email-table" id="email-list-table">
        <thead>
          <tr>
            <th>Subject</th>
            <th>Recipient</th>
            <th>Sent</th>
            <th class="text-center">Confirmed Opens</th>
            <th>Last Opened</th>
            <th class="text-center">Action</th>
          </tr>
        </thead>
        <tbody>
          <% emails.forEach(function(email) { %>
            <tr class="email-row" id="email-row-<%= email.id %>">
              <td class="cell-subject">
                <span class="subject-text"><%= email.subject || '(No subject)' %></span>
              </td>
              <td class="cell-recipient">
                <span class="recipient-text"><%= email.recipient || '(Unknown)' %></span>
              </td>
              <td class="cell-sent">
                <span class="sent-date" title="<%= new Date(email.sentAt).toISOString() %>">
                  <%= new Date(email.sentAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </span>
                <span class="sent-time">
                  <%= new Date(email.sentAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                </span>
              </td>
              <td class="cell-opens text-center">
                <% if (email.opensSummary.confirmed > 0) { %>
                  <span class="badge badge-opened"><%= email.opensSummary.confirmed %></span>
                  <% if (email.opensSummary.filtered > 0) { %>
                    <span class="badge-bot-hint" title="<%= email.opensSummary.filtered %> bot/proxy hit(s) excluded">+<%= email.opensSummary.filtered %> 🤖</span>
                  <% } %>
                <% } else if (email.opensSummary.filtered > 0) { %>
                  <span class="badge badge-unopened">0</span>
                  <span class="badge-bot-hint" title="<%= email.opensSummary.filtered %> bot/proxy hit(s) excluded">+<%= email.opensSummary.filtered %> 🤖</span>
                <% } else { %>
                  <span class="badge badge-unopened">0</span>
                <% } %>
              </td>
              <td class="cell-last-opened">
                <% if (email.lastRealOpen) { %>
                  <% var lastOpen = new Date(email.lastRealOpen.openedAt); %>
                  <span class="last-opened-date" title="<%= lastOpen.toISOString() %>">
                    <%= lastOpen.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                  <span class="last-opened-time">
                    <%= lastOpen.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                  </span>
                <% } else { %>
                  <span class="not-opened-yet">Not opened yet</span>
                <% } %>
              </td>
              <td class="cell-action text-center">
                <a href="/dashboard/email/<%= email.id %>?key=<%= dashboardKey %>" class="btn-details" id="details-btn-<%= email.id %>">
                  View Details →
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>

<script>
  (function() {
    const dashboardKey = '<%= dashboardKey %>';
    const pollInterval = 5000; // 5 seconds
    
    async function updateDashboard() {
      try {
        const response = await fetch(`/dashboard?format=json&key=${dashboardKey}`);
        if (!response.ok) {
          console.error('[Dashboard Live] Failed to fetch updates, status:', response.status);
          return;
        }
        
        const data = await response.json();
        const emails = data.emails || [];
        
        // 1. If currently in empty state and we have emails, reload the page to render the table
        const emptyState = document.querySelector('.empty-state');
        if (emptyState && emails.length > 0) {
          location.reload();
          return;
        }
        
        if (emails.length === 0) return;
        
        // 2. Update Stats Bar
        const statCards = document.querySelectorAll('.stat-card');
        if (statCards.length === 4) {
          const totalEmailsVal = emails.length;
          const confirmedOpensVal = emails.reduce((sum, e) => sum + (e.opensSummary ? e.opensSummary.confirmed : 0), 0);
          const emailsOpenedVal = emails.filter(e => e.opensSummary && e.opensSummary.confirmed > 0).length;
          const filteredVal = emails.reduce((sum, e) => sum + (e.opensSummary ? e.opensSummary.filtered : 0), 0);
          
          updateStatCard(statCards[0], totalEmailsVal);
          updateStatCard(statCards[1], confirmedOpensVal);
          updateStatCard(statCards[2], emailsOpenedVal);
          updateStatCard(statCards[3], filteredVal);
        }
        
        // 3. Update Table Rows
        const tbody = document.querySelector('#email-list-table tbody');
        if (!tbody) return;
        
        // Loop backwards (oldest to newest in the received list, which is sorted desc by sentAt)
        // so we prepend them in the correct relative order.
        for (let i = emails.length - 1; i >= 0; i--) {
          const email = emails[i];
          const rowId = `email-row-${email.id}`;
          const existingRow = document.getElementById(rowId);
          
          if (!existingRow) {
            // New email! Prepend it to the top of the table
            const tr = document.createElement('tr');
            tr.className = 'email-row row-highlight';
            tr.id = rowId;
            
            const sentAtDate = new Date(email.sentAt);
            const dateStr = sentAtDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            const timeStr = sentAtDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
            
            const summary = email.opensSummary || { confirmed: 0, filtered: 0 };
            const badgeClass = summary.confirmed > 0 ? 'badge-opened' : 'badge-unopened';
            
            let botHintHtml = '';
            if (summary.filtered > 0) {
              botHintHtml = `<span class="badge-bot-hint" title="${summary.filtered} bot/proxy hit(s) excluded">+${summary.filtered} 🤖</span>`;
            }
            
            let lastOpenedHtml = '<span class="not-opened-yet">Not opened yet</span>';
            if (email.lastRealOpen) {
              const lastOpenDate = new Date(email.lastRealOpen.openedAt);
              const loDateStr = lastOpenDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
              const loTimeStr = lastOpenDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
              lastOpenedHtml = `
                <span class="last-opened-date" title="${lastOpenDate.toISOString()}">${loDateStr}</span>
                <span class="last-opened-time">${loTimeStr}</span>
              `;
            }
            
            tr.innerHTML = `
              <td class="cell-subject">
                <span class="subject-text">${escapeHtml(email.subject || '(No subject)')}</span>
              </td>
              <td class="cell-recipient">
                <span class="recipient-text">${escapeHtml(email.recipient || '(Unknown)')}</span>
              </td>
              <td class="cell-sent">
                <span class="sent-date" title="${sentAtDate.toISOString()}">${dateStr}</span>
                <span class="sent-time">${timeStr}</span>
              </td>
              <td class="cell-opens text-center">
                <span class="badge ${badgeClass}">${summary.confirmed}</span>
                ${botHintHtml}
              </td>
              <td class="cell-last-opened">
                ${lastOpenedHtml}
              </td>
              <td class="cell-action text-center">
                <a href="/dashboard/email/${email.id}?key=${dashboardKey}" class="btn-details" id="details-btn-${email.id}">
                  View Details →
                </a>
              </td>
            `;
            
            tbody.insertBefore(tr, tbody.firstChild);
            
            // Remove highlight class after animation finishes
            setTimeout(() => {
              tr.classList.remove('row-highlight');
            }, 2000);
          } else {
            // Row exists, check for open count updates
            const badge = existingRow.querySelector('.cell-opens .badge');
            if (badge) {
              const summary = email.opensSummary || { confirmed: 0, filtered: 0 };
              const currentOpens = parseInt(badge.textContent, 10);
              if (summary.confirmed !== currentOpens) {
                // Update badge text and classes
                badge.textContent = summary.confirmed;
                if (summary.confirmed > 0) {
                  badge.className = 'badge badge-opened badge-pulse';
                } else {
                  badge.className = 'badge badge-unopened badge-pulse';
                }
                
                // Update bot hint
                let existingHint = existingRow.querySelector('.badge-bot-hint');
                if (summary.filtered > 0) {
                  if (!existingHint) {
                    existingHint = document.createElement('span');
                    existingHint.className = 'badge-bot-hint';
                    badge.parentNode.appendChild(existingHint);
                  }
                  existingHint.title = `${summary.filtered} bot/proxy hit(s) excluded`;
                  existingHint.textContent = `+${summary.filtered} 🤖`;
                }
                
                // Highlight the row
                existingRow.classList.add('row-highlight');
                
                // Update "Last Opened" cell
                const cellLastOpened = existingRow.querySelector('.cell-last-opened');
                if (cellLastOpened && email.lastRealOpen) {
                  const lastOpenDate = new Date(email.lastRealOpen.openedAt);
                  const loDateStr = lastOpenDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                  const loTimeStr = lastOpenDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                  cellLastOpened.innerHTML = `
                    <span class="last-opened-date" title="${lastOpenDate.toISOString()}">${loDateStr}</span>
                    <span class="last-opened-time">${loTimeStr}</span>
                  `;
                }
                
                // Clear animation classes after they complete
                setTimeout(() => {
                  badge.classList.remove('badge-pulse');
                  existingRow.classList.remove('row-highlight');
                }, 2000);
              }
            }
          }
        }
      } catch (err) {
        console.error('[Dashboard Live] Error polling data:', err);
      }
    }
    
    function updateStatCard(card, newValue) {
      const valElem = card.querySelector('.stat-value');
      if (valElem) {
        const currentVal = parseInt(valElem.textContent.replace(/,/g, ''), 10);
        if (currentVal !== newValue) {
          valElem.textContent = newValue.toLocaleString();
          // Add a scale/pulse effect to the value
          valElem.style.transform = 'scale(1.15)';
          valElem.style.transition = 'transform 0.2s ease-out';
          setTimeout(() => {
            valElem.style.transform = 'scale(1)';
          }, 200);
        }
      }
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }
    
    // Start polling on page load
    setInterval(updateDashboard, pollInterval);
  })();
</script>

<%- include('partials/footer') %>
